# ================================
# DATABASE CONFIGURATION
# ================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=

# ================================
# LLM API KEYS (Primary: Groq, Fallback: OpenAI)
# ================================
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ================================
# SARVAM AI — Primary for STT + TTS + Translation (Indian Languages)
# Get your key at: https://dashboard.sarvam.ai
# ================================
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_STT_MODEL=saarika:v2
SARVAM_TTS_MODEL=bulbul:v1
SARVAM_TRANSLATE_MODEL=mayura:v1
SARVAM_DEFAULT_SPEAKER=meera
SARVAM_DEFAULT_LANGUAGE=hi-IN

# ================================
# SPEECH-TO-TEXT FALLBACKS
# ================================
# Whisper runs locally, no API key needed
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ================================
# APPLICATION SETTINGS
# ================================
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development
ENABLE_SQL_FLOW=false

# Optional frontend deployment overrides.
# Set these when Streamlit and FastAPI are not reached through the same local host/port.
HEALTH_CHECK_URL=http://localhost:8000/health
WS_CHAT_URL=ws://localhost:8000/ws/chat

# ================================
# RATE LIMITING CONFIGURATION
# ================================
# Groq rate limits (requests per minute)
GROQ_RPM_LIMIT=30
GROQ_TOKENS_PER_MINUTE=14400

# OpenAI rate limits (requests per minute)
OPENAI_RPM_LIMIT=60
OPENAI_TOKENS_PER_MINUTE=90000

# ================================
# LLM MODEL CONFIGURATION
# ================================
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini

# ================================
# WEBSOCKET CONFIGURATION
# ================================
WS_MESSAGE_QUEUE_SIZE=100
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10

# ================================
# TTS CONFIGURATION
# ================================
TTS_PROVIDER=gtts
TTS_LANGUAGE=en
TTS_SPEED=1.0
